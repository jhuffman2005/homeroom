# ─── HomeRoom — Environment Variables ────────────────────────────────────────
# Copy this to .env.local for local dev
# Add all of these to your Vercel project settings under Environment Variables

# Supabase — get these from your Supabase project > Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — get this from console.anthropic.com > API Keys
# NOTE: This is server-side only (no VITE_ prefix) — never exposed to the browser
ANTHROPIC_API_KEY=sk-ant-your-key-here
